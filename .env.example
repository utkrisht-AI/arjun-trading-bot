BROKER=zerodha

# Zerodha
KITE_API_KEY=your_api_key
KITE_API_SECRET=your_api_secret
KITE_ACCESS_TOKEN=refreshed_daily

# Upstox (alternate)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# Claude API (for sentiment)
ANTHROPIC_API_KEY=your_key

# System
STARTING_CORPUS=2000
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
DRY_RUN=true
